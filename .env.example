# Supabase 配置
VITE_SUPABASE_URL=https://amiceplfaeofaofoveun.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# NVIDIA NIM API (OCR 功能，有才填)
VITE_NVIDIA_NIM_API_KEY=
VITE_NVIDIA_NIM_MODEL=meta/llama-3.2-11b-vision-instruct

# 伺服器端口
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# WhatsApp 通知（可在系統設定頁面填寫，這裡是備用）
WHATSAPP_SENDER=85291234567     # 發送號碼（公司 WhatsApp 號碼）
ADMIN_WHATSAPP=85291234567      # 接收號碼（老闆 WhatsApp 號碼）
WACLI_PATH=wacli                # wacli 路徑（Docker 已安裝，不用改）

# POSPAL 爬蟲
POSPAL_USERNAME=your-pospal-username
POSPAL_PASSWORD=your-pospal-password
POSPAL_STORE_NAME=your-store-name
RESTAURANT_ID=00000000-0000-0000-0000-000000000001
