# Supabase 配置
VITE_SUPABASE_URL=https://amiceplfaeofaofoveun.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# NVIDIA NIM API (OCR 功能，有才填)
VITE_NVIDIA_NIM_API_KEY=
VITE_NVIDIA_NIM_MODEL=meta/llama-3.2-11b-vision-instruct

# 伺服器端口
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Email 通知（使用 Resend HTTP API，避開 Render 免費版 SMTP 端口阻擋）
# 1. 前往 https://resend.com/signup 免費註冊
# 2. 到 https://resend.com/api-keys 建立 API Key
# 3. 填到下方（免費 3000 封/月）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=ULTRA POS <onboarding@resend.dev>  # 預設發件人（測試用）
ADMIN_EMAIL=Berryenna@yahoo.com.hk,shawnyauws@gmail.com  # 接收通知的信箱（逗號分隔）

# 舊 SMTP 配置（已棄用，Render 免費版阻擋 SMTP 端口 25/465/587）
# 僅在付費 Render 計劃或本地開發時可使用
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=handmadetarohk813@gmail.com
EMAIL_PASS=your-16-char-app-password

# WhatsApp 通知（可在系統設定頁面填寫，這裡是備用）
WHATSAPP_SENDER=85291234567     # 發送號碼（公司 WhatsApp 號碼）
ADMIN_WHATSAPP=85291234567      # 接收號碼（老闆 WhatsApp 號碼）
WACLI_PATH=wacli                # wacli 路徑（Docker 已安裝，不用改）

# POSPAL 爬蟲
POSPAL_USERNAME=your-pospal-username
POSPAL_PASSWORD=your-pospal-password
POSPAL_STORE_NAME=your-store-name
RESTAURANT_ID=00000000-0000-0000-0000-000000000001
