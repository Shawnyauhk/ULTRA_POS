# Environment Variables Example
# Copy this file to `.env` and fill in the values

# ===== 必须配置 =====

# Supabase 配置
VITE_SUPABASE_URL=https://amiceplfaeofaofoveun.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# NVIDIA NIM API (OCR 功能)
VITE_NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
VITE_NVIDIA_NIM_MODEL=meta/llama-3.2-11b-vision-instruct

# ===== 可选配置 =====

# 服务器端口 (默认 3001)
PORT=3001

# 环境 (production / development)
NODE_ENV=development

# 前端 URL (生产环境配置 CORS)
FRONTEND_URL=http://localhost:5173
